# ==========================================================
# Facebook Marketing API
# ==========================================================
# Access token để gọi Graph API Facebook (adaccounts, insights, campaign...)
# Nên dùng token dài hạn (long-lived token), không commit token thật lên git.
FACEBOOK_ACCESS_TOKEN=

# ==========================================================
# Google Cloud / BigQuery
# ==========================================================
# Đường dẫn file service account JSON để ứng dụng xác thực với GCP.
# Ví dụ: ./configs/service_account.json
GOOGLE_APPLICATION_CREDENTIALS=

# ID Project GCP chứa BigQuery datasets.
# Ví dụ: my-ads-project
BQ_PROJECT_ID=

# Dataset chứa dữ liệu raw (đổ trực tiếp từ API, ít biến đổi).
BQ_DATASET_RAW=ads_raw

# Dataset chứa dữ liệu mart/reporting (dữ liệu đã chuẩn hoá để BI đọc nhanh).
BQ_DATASET_MART=ads_mart

# ==========================================================
# Chế độ chạy ứng dụng
# ==========================================================
# APP_MODE:
# - daily    : chạy theo lịch cron, lấy dữ liệu mới nhất
# - backfill : chạy 1 lần để lấy dữ liệu lịch sử
APP_MODE=daily

# Ngày bắt đầu backfill (chỉ dùng khi APP_MODE=backfill).
# Hệ thống sẽ lấy dữ liệu từ ngày này đến hiện tại theo từng tháng.
RUN_BACKFILL_SINCE=2023-01-01

# ==========================================================
# Hiệu năng / xử lý song song
# ==========================================================
# Số worker chạy đồng thời khi fetch dữ liệu từ nhiều account.
# Tăng số này sẽ nhanh hơn nhưng dễ chạm rate limit API hơn.
MAX_WORKERS=10

# Kích thước batch ghi BigQuery mỗi lần insert.
# Batch lớn giảm số lần gọi API BigQuery, nhưng dùng RAM nhiều hơn.
BATCH_SIZE=500

# ==========================================================
# Lịch chạy cron
# ==========================================================
# Cron 5-field: minute hour day month weekday
# Giá trị hiện tại: chạy lúc 01:00, 08:00, 14:00, 17:00 mỗi ngày.
CRON_SCHEDULE=0 1,8,14,17 * * *

# ==========================================================
# Retry khi ghi BigQuery thất bại tạm thời
# ==========================================================
# Số lần retry tối đa.
MAX_RETRIES=3

# Delay ban đầu trước retry (các lần sau có thể tăng theo exponential backoff).
# Ví dụ hợp lệ: 500ms, 1s, 2s...
RETRY_BASE_DELAY=1s

# ==========================================================
# Safe mode / quan sát hệ thống
# ==========================================================
# Dry-run mode:
# - true  : chỉ fetch + transform, KHÔNG ghi BigQuery
# - false : chạy bình thường, có ghi BigQuery
APP_DRY_RUN=false

# Port cho health server nội bộ.
# Endpoints:
# - /health  : trạng thái ứng dụng
# - /metrics : metrics dạng text
HEALTH_PORT=8080

# ==========================================================
# Logging
# ==========================================================
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info

# LOG_ENV: development | production
LOG_ENV=development
